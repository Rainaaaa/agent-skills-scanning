# Behavioral analysis sandbox image — adapted from
# MaliciousAgentSkillsBench/code/Dockerfile.
#
# Differences from the upstream MASB Dockerfile:
#   - Default Debian apt sources (the upstream pinned mirrors.ustc.edu.cn —
#     not reachable from US-east cloud regions like Jetstream).
#   - Default pip index (PyPI), not Tsinghua mirror.
#   - NOVA_MODE=lite by default (pattern hooks, no ML dependencies). Override
#     to "full" for semantic NOVA, or "none" to skip NOVA entirely.
#
# Build:
#   docker build --build-arg NOVA_MODE=lite -t agentskills-sandbox .
#
# Used by orchestrator/run_batch.py to launch a fresh container per skill.

FROM python:3.10-slim

ARG NOVA_MODE=lite

# --- System dependencies --------------------------------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        strace \
        tcpdump \
        curl \
        wget \
        git \
        sudo \
        file \
        procps \
        iputils-ping \
        net-tools \
        jq \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# --- Node 18.x + Claude Code CLI ------------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# --- NOVA hooks (lite by default; set NOVA_MODE=full for ML version) ------
RUN if [ "$NOVA_MODE" != "none" ]; then \
        mkdir -p /opt/nova-protector/nova_hooks; \
    fi

COPY nova-requirements.txt /tmp/nova-requirements.txt
RUN if [ "$NOVA_MODE" = "full" ]; then \
        echo "Installing NOVA full ML stack..."; \
        pip install --no-cache-dir -r /tmp/nova-requirements.txt; \
    fi

COPY nova-hooks/ /opt/nova-protector/nova_hooks/
RUN if [ "$NOVA_MODE" != "none" ]; then \
        chmod +x /opt/nova-protector/nova_hooks/*.py && \
        echo "$NOVA_MODE" > /opt/nova-protector/nova_mode; \
    fi

# --- User + permissions ---------------------------------------------------
RUN useradd -m -s /bin/bash appuser && \
    mkdir -p /app/logs && \
    chown -R appuser:appuser /app && \
    if [ "$NOVA_MODE" != "none" ]; then \
        chown -R appuser:appuser /opt/nova-protector; \
    fi

ENV PYTHONUNBUFFERED=1
ENV PATH="/opt/nova-protector/nova_hooks:$PATH"
ENV NOVA_MODE=${NOVA_MODE}

USER appuser
CMD ["/bin/bash"]
